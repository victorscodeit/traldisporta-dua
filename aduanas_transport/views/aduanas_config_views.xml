<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Vista de formulario para Configuración de Aduanas -->
  <record id="view_aduanas_config_form" model="ir.ui.view">
    <field name="name">aduanas.config.form</field>
    <field name="model">aduanas.config.settings</field>
    <field name="arch" type="xml">
      <form string="Configuración Aduanas">
        <header>
          <button string="Aplicar" name="action_apply" type="object" class="oe_highlight"/>
          <button string="Cancelar" special="cancel"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1>
              <span>Configuración Aduanas AEAT</span>
            </h1>
          </div>
          
          <group string="Endpoints AEAT">
            <group string="Presentar DUA (exportación)">
              <field name="aeat_endpoint_cc515c" placeholder="https://..."/>
              <field name="aeat_endpoint_cc511c" placeholder="https://..."/>
              <field name="aeat_endpoint_ccaesc" placeholder="https://..."/>
              <field name="aeat_endpoint_cc507c" placeholder="https://..."/>
            </group>
            <group string="Importación (DUA)">
              <field name="aeat_endpoint_imp_decl" placeholder="https://prewww1.aeat.es/wlpl/ADIP-JDIT/ws/cci/CC415AV1SOAP"/>
              <field name="aeat_endpoint_imp_query" placeholder="https://prewww1.aeat.es/wlpl/ADIP-JDIT/ws/cci/ConsultaImportacionV3SOAP"/>
              <field name="aeat_endpoint_g4_dec" placeholder="https://prewww1.aeat.es/wlpl/ADDS-JDIT/ws/G4DecV1SOAP"/>
            </group>
            <group string="Bandeja AEAT">
              <field name="aeat_endpoint_bandeja" placeholder="https://..."/>
            </group>
            <group string="EXS (Declaración Sumaria Salida - IE615 V5)">
              <field name="aeat_endpoint_ie615" placeholder="https://prewww1.aeat.es/..."/>
            </group>
          </group>

          <group string="Certificado electrónico AEAT">
            <group>
              <field name="cert_attachment_id" readonly="1" optional="show"/>
              <field name="cert_upload" filename="cert_upload_filename" string="Subir certificado .p12/.pfx"/>
              <field name="cert_upload_filename" invisible="1"/>
              <field name="cert_password" password="True" placeholder="Contraseña del .p12"/>
              <field name="aeat_nif_firmante" placeholder="Opcional: solo si no firma el Exporter"/>
              <div class="text-muted" style="margin-top: 8px;">
                <strong>Para evitar 403 Forbidden</strong>: suba el .p12/.pfx de la AEAT y su contraseña.
                Para autodespacho la AEAT exige que el certificado sea del Exporter (remitente); por defecto se usa su NIF como firmante.
                Se usa <strong>cryptography</strong> (incluido en Odoo 16) para convertir a PEM y enviar con <strong>requests</strong>.
              </div>
            </group>
          </group>

          <group string="Conexión MSoft">
            <group>
              <field name="msoft_dsn" placeholder="DSN o Host de SQL Server"/>
              <field name="msoft_db" placeholder="Nombre de la base de datos"/>
            </group>
            <group>
              <field name="msoft_user" placeholder="Usuario"/>
              <field name="msoft_pass" password="True" placeholder="Contraseña"/>
            </group>
          </group>

          <group string="Procesamiento de Facturas PDF (IA/OCR)">
            <group>
              <field name="openai_api_key" password="True" placeholder="sk-..."/>
              <div class="text-muted" style="margin-top: 8px;">
                <strong>OpenAI API Key</strong> para usar GPT-4o Vision con splitting por páginas.
                Dejar vacío para usar OCR alternativo (pdfplumber/PyPDF2).
                <br/>
                <a href="https://platform.openai.com/api-keys" target="_blank">Obtener API Key de OpenAI</a>
              </div>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Acción para abrir la configuración -->
  <record id="action_aduanas_config" model="ir.actions.act_window">
    <field name="name">Configuración Aduanas AEAT</field>
    <field name="res_model">aduanas.config.settings</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
    <field name="view_id" ref="view_aduanas_config_form"/>
    <field name="context">{}</field>
  </record>

  <!-- Menú Configuración dentro de Aduanas -->
  <menuitem id="menu_aduanas_configuracion" name="Configuración"
            parent="menu_aduanas_root" action="action_aduanas_config" sequence="30"/>

</odoo>

